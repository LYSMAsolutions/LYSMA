  @@index([distributor_id], map: "idx_client_equipment_distribut")
}

model garanties {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  distributor_id       String    @db.Uuid
  client_id            String?   @db.Uuid
  assigned_user_id     String?   @db.Uuid
  magasin_id           String?   @db.Uuid
  status               String    @default("brouillon") @db.VarChar(30)
  marque_piece         String?   @db.VarChar(100)
  fournisseur          String?   @db.VarChar(100)
  reference_piece      String?   @db.VarChar(100)
  quantite             Int?      @default(1)
  n_bon_livraison      String?   @db.VarChar(100)
  date_bon_livraison   DateTime? @db.Date
  defaut_constate      String?
  date_montage_1       DateTime? @db.Date
  km_montage_1         Int?
  date_montage_2       DateTime? @db.Date
  km_montage_2         Int?
  marque_vehicule      String?   @db.VarChar(100)
  type_vehicule        String?   @db.VarChar(100)
  cylindree            String?   @db.VarChar(20)
  annee_vehicule       String?   @db.VarChar(10)
  immat_vehicule       String?   @db.VarChar(20)
  retour_fournisseur   Boolean?  @default(false)
  date_envoi_expert    DateTime? @db.Date
  date_decision        DateTime? @db.Date
  decision             String?   @db.VarChar(30)
  decision_bl          String?   @db.VarChar(100)
  decision_commentaire String?
  doc_carte_grise      String?
  doc_facture_1        String?
  doc_facture_2        String?
  doc_bl_1             String?
  doc_bl_2             String?
  commentaire          String?
  numero_garantie      String?   @db.VarChar(50)
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @db.Timestamptz(6)
 
  distributors  distributors @relation(fields: [distributor_id], references: [id], onDelete: Cascade)
  clients       clients?     @relation(fields: [client_id],      references: [id], onDelete: SetNull)
  users         users?       @relation(fields: [assigned_user_id], references: [id], onDelete: SetNull)
  stores        stores?      @relation(fields: [magasin_id],      references: [id], onDelete: SetNull)
 
  @@index([distributor_id], map: "idx_garanties_distributor")
  @@index([client_id],      map: "idx_garanties_client")
  @@index([assigned_user_id], map: "idx_garanties_user")
  @@index([status],         map: "idx_garanties_status")
}
