# ============================================================
# LIVO — Variables d'environnement
# Copier en .env.local et remplir les valeurs
# ============================================================

# ── Base de données Supabase ─────────────────────────────────
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-eu-west-3.pooler.supabase.com:5432/postgres"

# ── NextAuth ─────────────────────────────────────────────────
AUTH_URL="https://livo-app.com"
AUTH_SECRET=""  # openssl rand -base64 32
NEXTAUTH_URL="https://livo-app.com"
NEXTAUTH_SECRET=""  # compat NextAuth
SECURITY_ENCRYPTION_KEY="" # openssl rand -base64 32, utilisé pour chiffrer les secrets 2FA

# ── Resend (emails) ──────────────────────────────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="LYSMA Solutions <noreply@livo-app.com>"

# ── App ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://livo-app.com"
NEXT_PUBLIC_APP_NAME="LIVO"

# Super-admin / messagerie LYSMA
SUPER_ADMIN_MESSAGES_URL="https://livo-app.com/api/messages"
SUPER_ADMIN_INBOUND_SECRET=""

# API interne appelee par super-admin
INTERNAL_API_KEY=""
